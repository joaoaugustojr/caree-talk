              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/AuthTokenData"
                    }
                  },
                  "required": ["success", "data"]
                }
              }
            }
          }
        },
        "security": []
      }
    },
