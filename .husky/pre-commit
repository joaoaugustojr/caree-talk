#!/usr/bin/env bash
set -e

# Force a modern Node runtime for GUI Git environments.
NODE_BIN=""
for candidate in \
  "$HOME/.nvm/versions/node/v23.9.0/bin/node" \
  "$HOME/.nvm/versions/node/v20.20.2/bin/node" \
  "$HOME/.nvm/versions/node/v20.17.0/bin/node" \
  "$HOME/.nvm/versions/node/v20.15.0/bin/node"
do
  if [ -x "$candidate" ]; then
    NODE_BIN="$candidate"
    break
  fi
done

if [ -z "$NODE_BIN" ]; then
  NODE_BIN="$(command -v node || true)"
fi

if [ -z "$NODE_BIN" ]; then
  echo "husky: could not find node runtime" >&2
  exit 1
fi

"$NODE_BIN" ./node_modules/lint-staged/bin/lint-staged.js
